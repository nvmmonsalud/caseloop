# Keep true for deterministic, credential-free AI responses.
DEMO_MODE=true

# Live AI runs through Vercel AI Gateway. Vercel deployments use OIDC
# automatically; local development can use AI_GATEWAY_API_KEY or a fresh
# VERCEL_OIDC_TOKEN from `vercel env pull`.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5.6-terra
AI_REASONING_EFFORT=medium
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=2000
AI_FALLBACK_ON_ERROR=true

# AI evaluations are offline by default. Live evals require both opt-ins below,
# a server-only Gateway credential, and explicit token/cost ceilings.
CASEFLOW_EVAL_LIVE=false
CASEFLOW_EVAL_ALLOW_SPEND=
CASEFLOW_EVAL_MAX_TOTAL_TOKENS=10000
CASEFLOW_EVAL_MAX_OUTPUT_TOKENS=1200
CASEFLOW_EVAL_MAX_COST_USD=0.25

# Durable accounts and student work remain independent from live AI.
NEXT_PUBLIC_PERSISTENCE_ENABLED=false
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
